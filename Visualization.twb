            </column>
            <column caption='GDP Group' datatype='string' name='[Calculation_6170142606380347393]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [GDP_per_capita] &lt; 10000 THEN &quot;Low income&quot;&#10;ELSEIF [GDP_per_capita] &lt; 30000 THEN &quot;Middle income&quot;&#10;ELSE &quot;High income&quot;&#10;END' />
            </column>
            <column caption='Below Energy Poverty Line ' datatype='integer' name='[Calculation_6170142606381707266]' role='measure' type='quantitative'>
