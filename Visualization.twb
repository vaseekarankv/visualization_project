              <calculation class='tableau' formula='SUM(IF [Variable] = &apos;Renewables&apos; THEN [Value] END)&#10;/&#10;SUM(IF [Variable] IN (&apos;Fossil&apos;,&apos;Renewables&apos;,&apos;Clean&apos;,&apos;Other Renewables&apos;) THEN [Value] END)&#10;* 100' />
            </column>
