      <aliases enabled='yes' />
      <column caption='Asean' datatype='integer' name='[ASEAN]' role='measure' type='quantitative' />
      <column caption='Renewable Share (%)' datatype='real' name='[Calculation_2583447714836582402]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Variable] = &apos;Renewables&apos; THEN [Value] END)&#10;/&#10;SUM(IF [Variable] IN (&apos;Fossil&apos;,&apos;Renewables&apos;,&apos;Clean&apos;,&apos;Other Renewables&apos;) THEN [Value] END)&#10;* 100' />
      </column>
      <column caption='Group Label' datatype='string' name='[Calculation_3320982522864730112]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [EU] = 1 THEN &quot;European Union&quot;&#10;ELSEIF [G20] = 1 THEN &quot;G20&quot;&#10;ELSEIF [OECD] = 1 THEN &quot;OECD&quot;&#10;ELSEIF [ASEAN] = 1 THEN &quot;ASEAN&quot;&#10;ELSE &quot;Other Countries&quot;&#10;END' />
      </column>
      <column caption='Scaled Population' datatype='real' name='[Calculation_3343148677298020352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='( [Population] / 1000000 ) ^ 0.5' />
      </column>
      <column caption='OECD Status' datatype='string' name='[Calculation_3343148677302521857]' role='dimension' type='nominal'>
